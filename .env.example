# Application
NODE_ENV=development
APP_NAME=post-worker
APP_DEBUG=false

# Database (shared with post-service)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=post

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=post-worker:
REDIS_TTL=3600

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE=post_worker_queue
