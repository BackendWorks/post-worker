{
  "name": "@backendworks/post-worker",
  "version": "1.0.0",
  "description": "Post Worker — async RabbitMQ consumer for post-service events",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
